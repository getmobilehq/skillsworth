# Prove Your Worth — environment (handoff §17)
# Copy to .env.local and fill in. Never commit real values.

# Supabase — public (safe in client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — SERVER ONLY. Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — SERVER ONLY. Never ship to the client. (handoff §4, §8)
ANTHROPIC_API_KEY=

# raffu — shared Supabase project creds OR API base+key (open decision §19)
RAFFU_BASE_URL=
RAFFU_SERVICE_KEY=

# SMS OTP provider (Twilio / MessageBird) — server only
SMS_PROVIDER_SID=
SMS_PROVIDER_TOKEN=

# Email (Resend) — server only
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
