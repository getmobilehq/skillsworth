# Prove Your Worth — environment (handoff §17)
# Copy to .env.local and fill in. Never commit real values.

# Supabase — public (safe in client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — SERVER ONLY. Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — SERVER ONLY. Never ship to the client. (handoff §4, §8)
ANTHROPIC_API_KEY=

# raffu (§19 resolved: cross-project direct insert with raffu's ANON key).
# Point these at raffu's OWN Supabase project — NOT skillsworth's. RLS allows a
# public insert into entries while a raffle is 'collecting'. The weekly raffle
# (slug skill-worth-<ISOweek>) is created in raffu's dashboard, set collecting.
# Leave unset to no-op (entries still mirrored locally in raffle_entries).
RAFFU_SUPABASE_URL=
RAFFU_SUPABASE_ANON_KEY=

# raffu — OPS ONLY (scripts/ensure-weekly-raffle.mjs). NOT used by the running
# app; the app only ever uses the anon key above. Creating the weekly raffle
# needs raffu's owner RLS, hence the service-role key + the TTS admin's raffu
# user id. Keep out of the client/runtime env.
RAFFU_SERVICE_ROLE_KEY=
RAFFU_OWNER_ID=

# SMS OTP — Twilio Verify, configured in the SUPABASE DASHBOARD
# (Authentication → Providers → Phone → Twilio Verify: Account SID, Auth Token,
# Verify Service SID). The app does NOT read Twilio creds — Supabase calls
# Twilio server-side — so nothing is needed here for OTP.

# Email (Resend) — server only
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
